{
    "name": "Salty Miner",
    "version": "0.1",
    "description": "Salty Bet Bot",
    "manifest_version": 2,
    "permissions": [
        "*://www.saltybet.com/*",
        "storage",
        "*://localhost/*"
    ],
    "background": {
        "scripts": [
            "background_scripts/background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.saltybet.com/*"
            ],
            "js": [
                "third_party/jquery-3.3.1.min.js",
                "content_scripts/content.js"
            ]
        }
    ],
    "popup": "popup/popup.html"
}